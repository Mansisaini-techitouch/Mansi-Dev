package OOPS;

public class emp {
    String name;
    int age;
    emp(String name , int age){ // default constructor
      this.name= name;
      this.age = age;

    }


    public static void main(String[] args ){

        emp ob= new emp("Mansi" , 21);
        System.out.print(ob.name+" "+ob.age);

    }

}
