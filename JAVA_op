
package loops;

public class number {
    public static void main(String[] args) {

        for(int i = 1; i <= 5; i++) {
            for(int j = 5; j >= 1; j--) {

                if(i + j == 6) {   // important condition
                    System.out.print(i + " " + j + " ");
                }

            }
        }
    }




}

